# IBM watsonx.ai Credentials
IBM_API_KEY=your_ibm_api_key_here
IBM_PROJECT_ID=your_ibm_project_id_here
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com

# IBM Granite Model IDs
GRANITE_INSTRUCT_MODEL=ibm/granite-3-8b-instruct
GRANITE_VISION_MODEL=ibm/granite-vision-3-2-2b
GRANITE_EMBEDDING_MODEL=ibm/granite-embedding-30m-english

# Weather API (OpenWeatherMap)
WEATHER_API_KEY=your_openweathermap_api_key_here
WEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# Flask
FLASK_SECRET_KEY=your_very_secret_flask_key_here
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# Database
DATABASE_URL=sqlite:///database/smartfarming.db

# ChromaDB
CHROMA_DB_PATH=./database/chroma_db
CHROMA_COLLECTION_NAME=farming_knowledge

# File Upload
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=./uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png

# Reports
REPORTS_FOLDER=./reports
